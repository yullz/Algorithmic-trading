# Copy to .env and fill in. .env is git-ignored. NEVER commit real keys.
# For DATA ONLY (public OHLCV) you do NOT need any keys.

# Exchange (default: bybit for USDT-margined perpetual futures)
EXCHANGE=bybit

# Only needed for authenticated calls (balances / live orders).
# Leave blank for data + paper trading. For live, create TESTNET keys first
# at https://testnet.bybit.com — the executor targets testnet until you also
# set execution.testnet=false AND execution.allow_mainnet=true in config.yaml.
API_KEY=
API_SECRET=

# Hard safety switch. Live orders are IMPOSSIBLE unless this is exactly "true".
# Keep this false until you have paper-traded and backtested extensively.
# Live mode ALSO requires execution.mode=live in config.yaml, and mainnet
# additionally requires the double opt-in above. Creating a file named
# STOP_TRADING in the project root halts all new entries instantly.
ALLOW_LIVE_TRADING=false

# Final live gate: the executor also demands this exact phrase (or an
# interactive confirmation at startup) before its first real order.
# LIVE_TRADING_CONFIRM=YES-I-UNDERSTAND

# Optional passphrase used to decrypt an encrypted key file (see utils).
KEY_PASSPHRASE=
